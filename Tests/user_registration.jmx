        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Simple Controller - REGISTER VIA OAUTH">
          <stringProp name="TestPlan.comments">First we request provider api to with user email
The provider provides provider_name and provider_id
This confirms that the user is verified
Then we create one user object with the details received from the provider, allowing the user to change the username or name if needed
then we use this userid to create an oath account
</stringProp>
        </GenericController>
        <hashTree>
          <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="New Google Account / Github Account"/>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="HTTP Request - New Google Account">
              <stringProp name="HTTPSampler.domain">68da7a0c23ebc87faa304372.mockapi.io</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">/api/v1/oauth/oauth_email</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
              <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
                <collectionProp name="Arguments.arguments"/>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="JSON Extractor">
                <stringProp name="JSONPostProcessor.referenceNames">email;avatar;username;provider;provider_id;created_at</stringProp>
                <stringProp name="JSONPostProcessor.jsonPathExprs">$[0].email;$[0].avatar;$[0].username;$[0].provider;$[0].provider_id;$[0].created_at</stringProp>
                <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
                <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND;NOT_FOUND;NOT_FOUND;NOT_FOUND;NOT_FOUND;NOT_FOUND</stringProp>
              </JSONPostProcessor>
              <hashTree/>
            </hashTree>
            <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Check if provider, provider_id exists in oauth_table">
              <stringProp name="dataSource">postgresDB</stringProp>
              <stringProp name="queryType">Select Statement</stringProp>
              <stringProp name="query">SELECT user_id FROM oauth_account 
WHERE provider=&apos;${provider}&apos; AND provider_acc_id=&apos;${provider_id}&apos;</stringProp>
              <stringProp name="queryArguments"></stringProp>
              <stringProp name="queryArgumentsTypes"></stringProp>
              <stringProp name="variableNames">RESULT_user_id</stringProp>
              <stringProp name="resultVariable"></stringProp>
              <stringProp name="queryTimeout"></stringProp>
              <stringProp name="resultSetMaxRows"></stringProp>
              <stringProp name="resultSetHandler">Store as String</stringProp>
            </JDBCSampler>
            <hashTree>
              <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 Assertion">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def userId = vars.get(&quot;RESULT_user_id&quot;) // variable from JDBC Request
if (!userId || userId.trim().equalsIgnoreCase(&quot;null&quot;)) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;No oauth_account found for Google / cd8dbd5d26ee1ec6e1e8f211&quot;)
}</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223Assertion>
              <hashTree/>
            </hashTree>
            <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Check if email exists in user table">
              <stringProp name="dataSource">postgresDB</stringProp>
              <stringProp name="queryType">Select Statement</stringProp>
              <stringProp name="query">SELECT id FROM &quot;user&quot;
WHERE email=&apos;${email}&apos;;</stringProp>
              <stringProp name="queryArguments"></stringProp>
              <stringProp name="queryArgumentsTypes"></stringProp>
              <stringProp name="variableNames">RESULT_id</stringProp>
              <stringProp name="resultVariable"></stringProp>
              <stringProp name="queryTimeout"></stringProp>
              <stringProp name="resultSetMaxRows"></stringProp>
              <stringProp name="resultSetHandler">Store as String</stringProp>
            </JDBCSampler>
            <hashTree>
              <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 Assertion">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def userId = vars.get(&quot;RESULT_id&quot;) // variable from JDBC Request
if (!userId || userId.trim().equalsIgnoreCase(&quot;null&quot;)) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;No user found for given email&quot;)
}</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223Assertion>
              <hashTree/>
            </hashTree>
            <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Create new user and link oauth_account">
              <stringProp name="dataSource">postgresDB</stringProp>
              <stringProp name="queryType">Update Statement</stringProp>
              <stringProp name="query">BEGIN;

WITH new_user AS (
    INSERT INTO &quot;user&quot; (email, username, is_verified)
    VALUES (&apos;test@test.com&apos;, &apos;testuser&apos;, true)
    RETURNING id
)
INSERT INTO oauth_account (user_id, provider, provider_acc_id)
SELECT id, &apos;Google&apos;, &apos;provider_unique_id&apos; FROM new_user;

COMMIT;
</stringProp>
              <stringProp name="queryArguments"></stringProp>
              <stringProp name="queryArgumentsTypes"></stringProp>
              <stringProp name="variableNames"></stringProp>
              <stringProp name="resultVariable"></stringProp>
              <stringProp name="queryTimeout"></stringProp>
              <stringProp name="resultSetMaxRows"></stringProp>
              <stringProp name="resultSetHandler">Store as String</stringProp>
            </JDBCSampler>
