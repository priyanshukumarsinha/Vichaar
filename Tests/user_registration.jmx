            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor - calculate rowCount">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import java.nio.file.Files
import java.nio.file.Paths

// Path to your CSV file
def path = Paths.get(&quot;C:/Users/sneha/OneDrive/Documents/vichaarDB/user_login_email.csv&quot;)

// Count rows (excluding header if needed)
def lineCount = Files.readAllLines(path).size()

// Store in JMeter variable
vars.put(&quot;rowCount&quot;, String.valueOf(lineCount))</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
